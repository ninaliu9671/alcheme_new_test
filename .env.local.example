# Copy this file to .env.local (which is gitignored) and fill in your values.
# After editing, restart `npm run dev`.

# Your AI provider endpoint (chat-completions compatible)
# Examples:
#   https://api.openai.com/v1/chat/completions
#   https://api.deepseek.com/chat/completions
#   https://api.moonshot.cn/v1/chat/completions
AI_URL=

# Your API key — NEVER prefix with NEXT_PUBLIC_
AI_KEY=

# Model name your provider expects
AI_MODEL=gpt-4o-mini
